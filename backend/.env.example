# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/elder_companion

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── File Upload ─────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── App URL (for building file download URLs) ───────────
APP_BASE_URL=http://localhost:5000

# ── Optional: Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
